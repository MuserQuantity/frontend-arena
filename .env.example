# ---- server ---------------------------------------------------------------
# Bearer key required by all write endpoints (POST/PUT/PATCH/DELETE).
# Generate one:  openssl rand -hex 32
API_KEY=change-me

# Origin prefixed to asset urls returned by the API.
# Dev (client on :3000, API on :3001):  http://localhost:3001
# Production single origin:             leave empty (relative urls)
PUBLIC_BASE_URL=http://localhost:3001

# Where db.json + uploaded assets live (default: server/data)
# DATA_DIR=server/data

# ---- client (read by Vite, safe to expose) ---------------------------------
# API origin. Empty or / uses the same origin.
# Dev:  http://localhost:3001    Production same-origin:  /
VITE_API_BASE_URL=http://localhost:3001
